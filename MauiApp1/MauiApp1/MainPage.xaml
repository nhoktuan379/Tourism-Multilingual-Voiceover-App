<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:maps="http://schemas.microsoft.com/dotnet/2021/maui/maps"
    x:Class="MauiApp1.MainPage"
    xmlns:res="clr-namespace:MauiApp1.Resources.Languages"
    
    BackgroundColor="White">

    <!-- BẮT BUỘC PHẢI CÓ GRID GỐC NÀY ĐỂ CHỨA CẢ SCROLLVIEW VÀ FRAME -->
    <Grid RowDefinitions="Auto,*">

        <!-- ===== SCROLL UI ===== -->
        <ScrollView Grid.Row="0">
            <VerticalStackLayout
                Padding="30,0"
                Spacing="25">

                <Grid ColumnDefinitions="*,Auto"
                      VerticalOptions="Center">

                    <Label
                        x:Name="lblLogin"
                        Grid.Column="0"
                        Margin="0,50,0,0"
                        Text="{x:Static res:AppResources.Login}"
                        TextColor="Black"
                        FontAttributes="Bold"
                        Style="{StaticResource Headline}" />

                    <Frame x:Name="LangButton"
WidthRequest="40"
HeightRequest="40"
CornerRadius="20"
Padding="0"
BackgroundColor="White"
AbsoluteLayout.LayoutBounds="0.95,0.08,40,40"
AbsoluteLayout.LayoutFlags="PositionProportional">

                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnToggleLanguageMenu"/>
                        </Frame.GestureRecognizers>

                        <Image x:Name="CurrentLangImage"
    Source="vietnam.png"
    Aspect="AspectFill"/>
                    </Frame>

                    <!-- Dropdown KHÍT NGANG -->
                    <Frame x:Name="LangMenu"
IsVisible="False"
BackgroundColor="White"
CornerRadius="10"
Padding="6"
HasShadow="True"
AbsoluteLayout.LayoutBounds="0.95,0.15,-1,-1"
AbsoluteLayout.LayoutFlags="PositionProportional">

                        <VerticalStackLayout Spacing="8">

                            <Image Source="vietnam.png" WidthRequest="30" HeightRequest="30">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectVietnam"/>
                                </Image.GestureRecognizers>
                            </Image>

                            <Image Source="unitedkingdom.png" WidthRequest="30" HeightRequest="30">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectEnglish"/>
                                </Image.GestureRecognizers>
                            </Image>

                            <Image Source="japan.png" WidthRequest="30" HeightRequest="30">
                                <Image.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnSelectJapanese"/>
                                </Image.GestureRecognizers>
                            </Image>

                        </VerticalStackLayout>
                    </Frame>

                </Grid>

                <Image
                    Margin="0,70,0,70"
                    Source="login.jpg"
                    HeightRequest="185"
                    Aspect="AspectFit" />


                <Image
                    x:Name="QrCodeImage"
                    HeightRequest="200"
                    WidthRequest="200"
                    Opacity="0.8" />
                <Button
    Text="QUÉT MÃ TẠI TRẠM"
    BackgroundColor="DarkGreen"
    TextColor="White"
    FontAttributes="Bold"
    Clicked="OnScanButtonClicked"
    HorizontalOptions="Fill" />


                <Button
                    x:Name="CounterBtn"
                    Text="Click me"
                    TextColor="White"
                    Clicked="OnCounterClicked"
                    HorizontalOptions="Fill" />

            </VerticalStackLayout>
        </ScrollView>

       

    </Grid>

</ContentPage>
