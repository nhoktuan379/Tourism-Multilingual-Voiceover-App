@page
@model Admin.Pages.Index4Model
@{
    ViewData["Title"] = "Quản lý Tour";
    Layout = "_Layout";
}

<style>
    body {
        background: #f5f7fb;
    }

    .admin-container {
        display: grid;
        grid-template-columns: 420px 1fr;
        gap: 20px;
        height: 85vh;
    }

    .card {
        background: white;
        border-radius: 14px;
        padding: 20px;
        box-shadow: 0 6px 20px rgba(0,0,0,0.05);
    }

    .header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 15px;
    }

        .header h2 {
            margin: 0;
            font-weight: 600;
        }

    .btn-main {
        background: #0d47a1;
        color: white;
        border-radius: 8px;
        padding: 8px 14px;
        border: none;
    }

        .btn-main:hover {
            background: #1565c0;
        }

    .map-side {
        border-radius: 14px;
        overflow: hidden;
        border: 1px solid #ddd;
    }

    iframe {
        width: 100%;
        height: 100%;
        border: none;
    }

    /* ===== TOUR CARD ===== */
    .tour-card {
        display: flex;
        gap: 10px;
        padding: 10px;
        border-radius: 10px;
        margin-bottom: 10px;
        border: 1px solid #eee;
        transition: 0.2s;
    }

        .tour-card:hover {
            border-color: #0d47a1;
            transform: translateY(-2px);
        }

    .tour-img {
        width: 80px;
        height: 60px;
        border-radius: 6px;
        object-fit: cover;
        background: #eee;
    }

    .tour-info {
        flex: 1;
    }

    .tour-title {
        font-weight: 600;
        font-size: 14px;
    }

    .tour-meta {
        font-size: 12px;
        color: gray;
    }

    .delete-btn {
        background: transparent;
        border: none;
        color: red;
        font-size: 14px;
    }

    /* ===== POI LIST ===== */
    .poi-item {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px;
        border-left: 4px solid #0d47a1;
        background: #fafafa;
        margin-bottom: 6px;
        border-radius: 6px;
    }

    .order-number {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: #0d47a1;
        color: white;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
    }

    input {
        border-radius: 6px !important;
    }
</style>

<div class="header">
    <h2>🎯 Quản lý Lộ trình Tour</h2>

    <div>
        <button id="btnStartTour" class="btn-main" onclick="startTourCreation()">+ Tạo Tour</button>
        <button id="btnFinishTour" class="btn btn-success" onclick="finishTourCreation()" style="display:none;">✔ Lưu</button>
        <button id="btnCancelTour" class="btn btn-danger" onclick="cancelTourCreation()" style="display:none;">✖ Hủy</button>
    </div>
</div>

<div class="admin-container">

    <!-- LEFT PANEL -->
    <div class="card">

        <!-- FORM -->
        <div id="tourInfoForm" style="display:none;">
            <h5>Thông tin Tour</h5>

            <input id="txtTourName" class="form-control mb-2" placeholder="Tên tour" />
            <input id="txtCoverImage" class="form-control mb-2" placeholder="URL ảnh bìa" />

            <div class="row">
                <div class="col">
                    <input id="txtDistance" type="number" class="form-control mb-2" placeholder="Khoảng cách (km)" />
                </div>
                <div class="col">
                    <input id="txtDuration" class="form-control mb-2" placeholder="Thời gian" />
                </div>
            </div>

            <hr />

            <h6>📍 Lộ trình:</h6>
            <div id="selectedPoiList"></div>
        </div>

        <!-- EXISTING TOURS -->
        <div id="existingTours">
            <h5>Danh sách Tour</h5>

            @foreach (var t in Model.ExistingTours)
            {
                <div class="tour-card">
                    <img src="@(t.CoverImage ?? "/images/no-image.png")" class="tour-img" />

                    <div class="tour-info">
                        <div class="tour-title">@t.TourName</div>
                        <div class="tour-meta">
                            @(t.TotalDistance ?? 0) km • @t.Duration
                        </div>
                    </div>

                    <button class="delete-btn" onclick="deleteTour(@t.TourID)">🗑</button>
                </div>
            }
        </div>

    </div>

    <!-- MAP -->
    <div class="map-side">
        <iframe id="mapFrame" src="http://127.0.0.1:5500/goong_map.html"></iframe>
    </div>

</div>

@section Scripts {
    <script>
        const mapIframe = document.getElementById('mapFrame');
        let selectedTourPoints = [];

        function startTourCreation() {
            selectedTourPoints = [];

            document.getElementById('btnStartTour').style.display = 'none';
            document.getElementById('existingTours').style.display = 'none';

            document.getElementById('btnFinishTour').style.display = 'inline-block';
            document.getElementById('btnCancelTour').style.display = 'inline-block';
            document.getElementById('tourInfoForm').style.display = 'block';

            mapIframe.contentWindow.postMessage({ type: "ENABLE_TOUR_MODE", active: true }, "*");

            renderSelectedList();
        }

        window.addEventListener("message", function (event) {
            if (event.data.type === "ADD_TO_TOUR") {
                const poi = event.data.poi;

                if (!selectedTourPoints.find(p => p.id === poi.id)) {
                    selectedTourPoints.push(poi);
                    renderSelectedList();
                }
            }
        });

        function renderSelectedList() {
            const container = document.getElementById('selectedPoiList');

            if (selectedTourPoints.length === 0) {
                container.innerHTML = '<p style="color:gray;">Chọn điểm trên bản đồ...</p>';
                return;
            }

            container.innerHTML = selectedTourPoints.map((p, i) => `
                    <div class="poi-item">
                        <div class="order-number">${i + 1}</div>
                        <span>${p.name}</span>
                    </div>
                `).join('');
        }

        async function finishTourCreation() {
            const data = {
                tourName: document.getElementById('txtTourName').value,
                coverImage: document.getElementById('txtCoverImage').value,
                totalDistance: parseFloat(document.getElementById('txtDistance').value) || 0,
                duration: document.getElementById('txtDuration').value,
                poiIds: selectedTourPoints.map(p => p.id)
            };

            if (!data.tourName || data.poiIds.length < 2) {
                alert("Nhập tên và chọn ít nhất 2 điểm!");
                return;
            }

            const res = await fetch('?handler=SaveTour', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });

            const result = await res.json();

            if (result.success) {
                alert("✔ Lưu thành công");
                location.reload();
            } else {
                alert("❌ " + result.message);
            }
        }

        function cancelTourCreation() {
            location.reload();
        }
    </script>
}